# ── Copy this file to .env and fill in your values ──────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────
# Get your free SAM.gov API key at: https://api.data.gov/signup
SAM_API_KEY=your_sam_gov_api_key_here

# ── BILLING (skip in dev) ─────────────────────────────────────────────────────
BILLING_ENABLED=false
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SOLO=price_...
STRIPE_PRICE_TEAM=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── EMAIL (Resend) ────────────────────────────────────────────────────────────
# Get a free key at: https://resend.com (3,000 emails/month free)
# Verify your sending domain in the Resend dashboard first.
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com

# ── SERVER ────────────────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ── DEV ───────────────────────────────────────────────────────────────────────
# Set DEV_MODE=true to skip auth checks entirely during local development
DEV_MODE=true
DEV_API_KEY=dev-key-local

LOG_LEVEL=INFO
LOG_FORMAT=console
